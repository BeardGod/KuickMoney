{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "KuickMoney",
  "identifier": "com.kuickmoney.retail-bot",
  "version": "0.1.0",
  "build": {
    "devtools": true,
    "frontendDist": "../frontend",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "KuickMoney - Retail Bot",
        "width": 1100,
        "height": 750,
        "center": true,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "zip"],
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    }
  }
}
